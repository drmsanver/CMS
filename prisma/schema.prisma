generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------
// Multi-Tenancy & Org Structure
// ---------------------------------------------

model Organization {
  id        String   @id @default(cuid())
  name      String
  subdomain String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campuses  Campus[]
  users     User[]
}

model Campus {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  fullName       String?      // Full name of the school/branch
  shortName      String?      // Short name or code
  principalName  String?      // Principal's name
  address        String?
  phoneNumbers   String[]     // Multiple phone numbers
  logoUrl        String?      // URL to logo image
  websiteUrl     String?      // School website
  email          String?      // General contact email
  socialMedia    Json?        // { twitter: "...", facebook: "...", etc }
  orderWeight    Int          @default(0) // Higher value = listed at top
  images         String[]     // Multiple picture URLs
  grades         String[]     // Grades available on this campus

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users          User[]
  students       Student[]
  classrooms     Classroom[]
  gradeGroups    GradeGroup[]
  semesters      Semester[]
  goals          Goal[]
  activityTypes  ActivityType[]
  participants   Participant[]
}

// ---------------------------------------------
// Users & Role-Based Access Control (RBAC)
// ---------------------------------------------

enum Role {
  SUPER_ADMIN
  ORG_ADMIN
  PRINCIPAL
  COUNSELOR
  COORDINATOR
  TEACHER
  PARENT
  STUDENT
}

model User {
  id             String       @id @default(cuid())
  organizationId String
  campusId       String?      // Optional: ORG_ADMIN might not belong to a single campus
  role           Role         @default(STUDENT)
  email          String       @unique
  name           String
  passwordHash   String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campus         Campus?      @relation(fields: [campusId], references: [id], onDelete: SetNull)

  // Relations for specific roles
  counselingRecords  CounselingRecord[]          @relation("CounselorRecords")
  observationReports ObservationReport[]         @relation("TeacherReports")
  assignedTasks      Task[]                      @relation("AssignedTo")
  createdTasks       Task[]                      @relation("CreatedBy")
  events             Event[]                     @relation("Organizer")
  primaryClassroom   Classroom?                  @relation("PrimaryTeacher")
  counselorGrades    CounselorGradeAssignment[]  @relation("CounselorGrades")
}

// ---------------------------------------------
// Classrooms
// ---------------------------------------------

model Classroom {
  id               String   @id @default(cuid())
  campusId         String
  name             String       // e.g. "3-A", "5-B"
  gradeLevel       String       // e.g. "3", "5", "Kindergarten"
  primaryTeacherId String?  @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  campus           Campus   @relation(fields: [campusId], references: [id], onDelete: Cascade)
  primaryTeacher   User?    @relation("PrimaryTeacher", fields: [primaryTeacherId], references: [id])
  students         Student[]
}

// ---------------------------------------------
// Grade Groups (Coordinator focus)
// ---------------------------------------------

model GradeGroup {
  id        String   @id @default(cuid())
  campusId  String
  name      String   // e.g. "Elementary School", "Middle School"
  grades    String[] // e.g. ["1", "2", "3", "4"]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campus    Campus   @relation(fields: [campusId], references: [id], onDelete: Cascade)
  tasks     Task[]   @relation("TaskToGradeGroup")
}

// ---------------------------------------------
// Semester, Goal & Activity Infrastructure
// ---------------------------------------------

model Semester {
  id        String   @id @default(cuid())
  campusId  String
  name      String   // e.g. "2025-2026 Spring", "2025-2026 1st Quarter"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campus    Campus   @relation(fields: [campusId], references: [id], onDelete: Cascade)
  tasks     Task[]
}

model Goal {
  id          String   @id @default(cuid())
  campusId    String
  code        String   // Unique goal code
  title       String   // Short Title
  description String?  @db.Text
  mandatedBy  String   // MEB, "Name of the College", School Principle, Teachers, Counselors
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campus      Campus   @relation(fields: [campusId], references: [id], onDelete: Cascade)
  tasks       Task[]   @relation("TaskToGoals")
}

model ActivityType {
  id        String   @id @default(cuid())
  campusId  String
  name      String   // e.g. "seminar", "meeting", "exhibition", "training"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campus    Campus   @relation(fields: [campusId], references: [id], onDelete: Cascade)
  tasks     Task[]
}

model Participant {
  id        String   @id @default(cuid())
  campusId  String
  name      String   // e.g. "Main College", "Specific Campus"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campus    Campus   @relation(fields: [campusId], references: [id], onDelete: Cascade)
  tasks     Task[]   @relation("TaskToParticipants")
}

// ---------------------------------------------
// Counselor Grade Assignments
// ---------------------------------------------

model CounselorGradeAssignment {
  id         String @id @default(cuid())
  userId     String
  gradeLevel String

  user       User   @relation("CounselorGrades", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gradeLevel])
}

// ---------------------------------------------
// Core Entities: Students
// ---------------------------------------------

model Student {
  id             String       @id @default(cuid())
  campusId       String
  classroomId    String?
  studentNumber  String       @unique
  firstName      String
  lastName       String
  gradeLevel     String
  dateOfBirth    DateTime?
  
  // Parent Contact Information
  fatherName     String?
  fatherPhone    String?
  fatherEmail    String?
  motherName     String?
  motherPhone    String?
  motherEmail    String?
  defaultContact String?      // "FATHER" or "MOTHER"

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  campus         Campus       @relation(fields: [campusId], references: [id], onDelete: Cascade)
  classroom      Classroom?   @relation(fields: [classroomId], references: [id], onDelete: SetNull)
  records        CounselingRecord[]
  observations   ObservationReport[]
}

// ---------------------------------------------
// Counseling & Observations (MEB Compliant)
// ---------------------------------------------

model CounselingRecord {
  id            String   @id @default(cuid())
  studentId     String
  counselorId   String
  date          DateTime @default(now())
  subject       String
  notes         String   @db.Text
  isConfidential Boolean @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  counselor     User     @relation("CounselorRecords", fields: [counselorId], references: [id])
}

model ObservationReport {
  id            String   @id @default(cuid())
  studentId     String
  teacherId     String
  date          DateTime @default(now())
  behaviorType  String
  notes         String   @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher       User     @relation("TeacherReports", fields: [teacherId], references: [id])
}

// ---------------------------------------------
// Tasks & Events Focus
// ---------------------------------------------

model Task {
  id            String   @id @default(cuid())
  title         String
  description   String?  @db.Text
  startDate     DateTime?
  dueDate       DateTime?
  status        String   @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED
  
  semesterId    String?
  activityTypeId String?
  assignedToId  String
  createdById   String
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  assignedTo    User     @relation("AssignedTo", fields: [assignedToId], references: [id])
  createdBy     User     @relation("CreatedBy", fields: [createdById], references: [id])
  
  semester      Semester? @relation(fields: [semesterId], references: [id])
  activityType  ActivityType? @relation(fields: [activityTypeId], references: [id])
  
  gradeGroups   GradeGroup[] @relation("TaskToGradeGroup")
  goals         Goal[]       @relation("TaskToGoals")
  participants  Participant[] @relation("TaskToParticipants")
  attachments   Attachment[]
}

model Attachment {
  id        String   @id @default(cuid())
  fileName  String
  fileUrl   String
  taskId    String
  createdAt DateTime @default(now())

  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Event {
  id            String   @id @default(cuid())
  title         String
  description   String?  @db.Text
  eventType     String   // SEMINAR, MEETING, COUNSELING_GROUP
  startTime     DateTime
  endTime       DateTime
  organizerId   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  organizer     User     @relation("Organizer", fields: [organizerId], references: [id])
}

